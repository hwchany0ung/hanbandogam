# 한반도감 환경변수 예시
# 실제 값은 .env 에 작성 (git 추적 제외)

# === 필수 ===
ANTHROPIC_API_KEY=sk-ant-...
UPSTAGE_API_KEY=up_...

# === 선택 ===
# Claude 모델 (기본: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# SQLite DB 경로 (기본: ./hanbando.db)
DATABASE_URL=sqlite:///./hanbando.db

# CORS 허용 오리진 (쉼표 구분, 기본: localhost)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 데모 모드: 1로 설정 시 data/demo_cache/ 에서 즉시 반환 (발표 직전 토글)
APP_DEMO_MODE=0
