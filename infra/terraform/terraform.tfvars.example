# terraform.tfvars — 실제 값으로 채워 terraform.tfvars 로 복사 후 사용
# ⚠️ terraform.tfvars 는 .gitignore 에 포함됨 (API 키/IP 노출 방지)

aws_region       = "ap-northeast-2"
project_name     = "hanbando"
instance_type    = "t3.small"
key_pair_name    = "hanbando"          # AWS 콘솔에서 생성한 키페어 이름
my_ip_cidr       = "x.x.x.x/32"       # 내 현재 IP (https://checkip.amazonaws.com)
s3_bucket_suffix = "popo"             # 버킷명 충돌 방지용 접미사
